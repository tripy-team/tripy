generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  planTier           String              @default("free") @map("plan_tier")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  alertSubscriptions AlertSubscription[]
  clients            Client[]
  households         Household[]
  tripRequests       TripRequest[]
  users              User[]

  @@map("organizations")
}

model User {
  id                   String                    @id @default(cuid())
  organizationId       String                    @map("organization_id")
  firstName            String                    @map("first_name")
  lastName             String                    @map("last_name")
  email                String                    @unique
  passwordHash         String                    @map("password_hash")
  role                 UserRole                  @default(advisor)
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  ledgerEntries        BalanceLedgerEntry[]
  ownedClients         Client[]
  resolvedInferences   InferredPreference[]
  preferenceChangeLogs PreferenceChangeLog[]
  recommendationRuns   RecommendationRun[]
  tripBriefs           TripBrief[]
  tripRequests         TripRequest[]
  walletAccounts       WalletAccount[]
  walletConnections    WalletConnection[]
  walletSyncRuns       WalletSyncRun[]
  organization         Organization              @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("users")
}

model Client {
  id                     String                             @id @default(cuid())
  organizationId         String                             @map("organization_id")
  ownerUserId            String                             @map("owner_user_id")
  firstName              String                             @map("first_name")
  lastName               String                             @map("last_name")
  email                  String?
  phone                  String?
  dateOfBirth            DateTime?                          @map("date_of_birth")
  notes                  String?
  status                 ClientStatus                       @default(active)
  createdAt              DateTime                           @default(now()) @map("created_at")
  updatedAt              DateTime                           @updatedAt @map("updated_at")
  clientType             ClientType                         @default(individual) @map("client_type")
  isSelfClient           Boolean                            @default(false) @map("is_self_client")
  alertSubscriptions     AlertSubscription[]
  businessProfile        BusinessProfile?
  businessTravelerLinks  BusinessTraveler[]                 @relation("BusinessTravelerLinkedClient")
  intakes                ClientIntake[]
  loyaltyBalances        ClientLoyaltyBalance[]
  preferences            ClientPreference?
  organization           Organization                       @relation(fields: [organizationId], references: [id])
  owner                  User                               @relation(fields: [ownerUserId], references: [id])
  familyMembers          FamilyMember[]                     @relation("ClientFamilyMembers")
  linkedFromFamilyMember FamilyMember?                      @relation("LinkedFamilyMember")
  followUpSuggestions    FollowUpSuggestion[]
  groupMemberships       GroupMember[]                      @relation("GroupMemberLinkedClient")
  groupProfile           GroupProfile?
  groupSettlements       GroupSettlement[]
  householdMembers       HouseholdMember[]
  inferredPreferences    InferredPreference[]
  intakeFormTokens       IntakeFormToken[]
  pointSourceAllocations RecommendationTravelerAllocation[] @relation("PointSource")
  tripBriefs             TripBrief[]
  tripRequests           TripRequest[]
  tripTravelers          TripTraveler[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([ownerUserId])
  @@map("clients")
}

model Household {
  id                 String                 @id @default(cuid())
  organizationId     String                 @map("organization_id")
  name               String
  notes              String?
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  alertSubscriptions AlertSubscription[]
  loyaltyBalances    ClientLoyaltyBalance[]
  members            HouseholdMember[]
  organization       Organization           @relation(fields: [organizationId], references: [id])
  tripRequests       TripRequest[]

  @@index([organizationId])
  @@map("households")
}

model HouseholdMember {
  id                    String    @id @default(cuid())
  householdId           String    @map("household_id")
  clientId              String    @map("client_id")
  relationshipLabel     String?   @map("relationship_label")
  canRedeemForHousehold Boolean   @default(false) @map("can_redeem_for_household")
  createdAt             DateTime  @default(now()) @map("created_at")
  client                Client    @relation(fields: [clientId], references: [id])
  household             Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, clientId])
  @@map("household_members")
}

model FamilyMember {
  id             String    @id @default(cuid())
  clientId       String    @map("client_id")
  name           String
  relationship   String
  email          String?
  phone          String?
  dateOfBirth    DateTime? @map("date_of_birth")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  linkedClientId String?   @unique @map("linked_client_id")
  client         Client    @relation("ClientFamilyMembers", fields: [clientId], references: [id], onDelete: Cascade)
  linkedClient   Client?   @relation("LinkedFamilyMember", fields: [linkedClientId], references: [id])

  @@index([clientId])
  @@map("family_members")
}

model LoyaltyProgram {
  id                     String                             @id @default(cuid())
  code                   String                             @unique
  name                   String
  category               ProgramCategory
  issuer                 String?
  supportsTransfer       Boolean                            @default(false) @map("supports_transfer")
  supportsPooling        Boolean                            @default(false) @map("supports_pooling")
  supportsExpiration     Boolean                            @default(false) @map("supports_expiration")
  defaultPointValueCents Float?                             @map("default_point_value_cents")
  createdAt              DateTime                           @default(now()) @map("created_at")
  updatedAt              DateTime                           @updatedAt @map("updated_at")
  alertSubscriptions     AlertSubscription[]
  balances               ClientLoyaltyBalance[]
  poolingRules           ProgramPoolingRule[]
  transferRulesFrom      ProgramTransferRule[]              @relation("TransferFrom")
  transferRulesTo        ProgramTransferRule[]              @relation("TransferTo")
  travelerAllocations    RecommendationTravelerAllocation[]
  transferBonusesFrom    TransferBonus[]                    @relation("BonusFrom")
  transferBonusesTo      TransferBonus[]                    @relation("BonusTo")

  @@map("loyalty_programs")
}

model ClientLoyaltyBalance {
  id               String               @id @default(cuid())
  clientId         String               @map("client_id")
  householdId      String?              @map("household_id")
  loyaltyProgramId String               @map("loyalty_program_id")
  balance          Int                  @default(0)
  expirationDate   DateTime?            @map("expiration_date")
  source           BalanceSource        @default(manual)
  lastVerifiedAt   DateTime?            @map("last_verified_at")
  notes            String?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  ledgerEntries    BalanceLedgerEntry[]
  client           Client               @relation(fields: [clientId], references: [id])
  household        Household?           @relation(fields: [householdId], references: [id])
  loyaltyProgram   LoyaltyProgram       @relation(fields: [loyaltyProgramId], references: [id])

  @@index([clientId])
  @@index([loyaltyProgramId])
  @@map("client_loyalty_balances")
}

model BalanceLedgerEntry {
  id                     String               @id @default(cuid())
  clientLoyaltyBalanceId String               @map("client_loyalty_balance_id")
  previousBalance        Int                  @map("previous_balance")
  newBalance             Int                  @map("new_balance")
  changeReason           String               @map("change_reason")
  changedByUserId        String               @map("changed_by_user_id")
  createdAt              DateTime             @default(now()) @map("created_at")
  changedBy              User                 @relation(fields: [changedByUserId], references: [id])
  balance                ClientLoyaltyBalance @relation(fields: [clientLoyaltyBalanceId], references: [id], onDelete: Cascade)

  @@map("balance_ledger_entries")
}

model ProgramTransferRule {
  id                         String         @id @default(cuid())
  fromProgramId              String         @map("from_program_id")
  toProgramId                String         @map("to_program_id")
  ratioNumerator             Int            @default(1) @map("ratio_numerator")
  ratioDenominator           Int            @default(1) @map("ratio_denominator")
  minimumTransferAmount      Int?           @map("minimum_transfer_amount")
  transferIncrement          Int?           @map("transfer_increment")
  estimatedTransferTimeHours Int?           @map("estimated_transfer_time_hours")
  isIrreversible             Boolean        @default(true) @map("is_irreversible")
  isActive                   Boolean        @default(true) @map("is_active")
  notes                      String?
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")
  fromProgram                LoyaltyProgram @relation("TransferFrom", fields: [fromProgramId], references: [id])
  toProgram                  LoyaltyProgram @relation("TransferTo", fields: [toProgramId], references: [id])

  @@index([fromProgramId, toProgramId])
  @@map("program_transfer_rules")
}

model ProgramPoolingRule {
  id               String         @id @default(cuid())
  loyaltyProgramId String         @map("loyalty_program_id")
  poolingScope     PoolingScope   @map("pooling_scope")
  notes            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  loyaltyProgram   LoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id])

  @@map("program_pooling_rules")
}

model TransferBonus {
  id            String         @id @default(cuid())
  fromProgramId String         @map("from_program_id")
  toProgramId   String         @map("to_program_id")
  bonusPercent  Int            @map("bonus_percent")
  startsAt      DateTime       @map("starts_at")
  endsAt        DateTime       @map("ends_at")
  sourceUrl     String?        @map("source_url")
  sourceLabel   String?        @map("source_label")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  fromProgram   LoyaltyProgram @relation("BonusFrom", fields: [fromProgramId], references: [id])
  toProgram     LoyaltyProgram @relation("BonusTo", fields: [toProgramId], references: [id])

  @@index([fromProgramId, toProgramId, endsAt])
  @@map("transfer_bonuses")
}

model WalletConnection {
  id                   String                 @id @default(cuid())
  userId               String                 @map("user_id")
  provider             WalletProvider
  providerConnectionId String?                @map("provider_connection_id")
  displayName          String?                @map("display_name")
  status               WalletConnectionStatus @default(active)
  consentScope         Json?                  @map("consent_scope")
  lastSyncedAt         DateTime?              @map("last_synced_at")
  lastError            String?                @map("last_error")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  accounts             WalletAccount[]
  syncRuns             WalletSyncRun[]
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider, providerConnectionId])
  @@map("wallet_connections")
}

model WalletAccount {
  id                     String              @id @default(cuid())
  connectionId           String?             @map("connection_id")
  userId                 String              @map("user_id")
  providerAccountId      String?             @map("provider_account_id")
  programCode            String              @map("program_code")
  programName            String              @map("program_name")
  ownerLabel             String?             @map("owner_label")
  currencyType           WalletCurrencyType  @map("currency_type")
  accountMask            String?             @map("account_mask")
  balance                Int                 @default(0)
  expirationDate         DateTime?           @map("expiration_date")
  eliteStatus            String?             @map("elite_status")
  source                 WalletAccountSource @default(sync)
  visibility             WalletVisibility    @default(exact)
  enabledForOptimization Boolean             @default(true) @map("enabled_for_optimization")
  lastSyncedAt           DateTime?           @map("last_synced_at")
  lastManualEditAt       DateTime?           @map("last_manual_edit_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  connection             WalletConnection?   @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  syncEvents             WalletSyncEvent[]
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, providerAccountId], name: "wallet_accounts_connection_provider_account_key")
  @@index([userId])
  @@index([connectionId])
  @@index([programCode])
  @@map("wallet_accounts")
}

model WalletSyncRun {
  id              String            @id @default(cuid())
  connectionId    String?           @map("connection_id")
  userId          String            @map("user_id")
  provider        WalletProvider
  status          WalletSyncStatus  @default(running)
  startedAt       DateTime          @default(now()) @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  accountsUpdated Int               @default(0) @map("accounts_updated")
  errorCode       String?           @map("error_code")
  errorMessage    String?           @map("error_message")
  connection      WalletConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  events          WalletSyncEvent[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@map("wallet_sync_runs")
}

model WalletSyncEvent {
  id                     String         @id @default(cuid())
  walletAccountId        String         @map("wallet_account_id")
  syncRunId              String?        @map("sync_run_id")
  previousBalance        Int?           @map("previous_balance")
  newBalance             Int            @map("new_balance")
  delta                  Int            @default(0)
  reason                 String
  rawProviderPayloadHash String?        @map("raw_provider_payload_hash")
  createdAt              DateTime       @default(now()) @map("created_at")
  account                WalletAccount  @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  syncRun                WalletSyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([walletAccountId])
  @@index([syncRunId])
  @@map("wallet_sync_events")
}

model ClientPreference {
  id                         String                @id @default(cuid())
  clientId                   String                @unique @map("client_id")
  preferredCabin             CabinPreference       @default(economy) @map("preferred_cabin")
  prefersNonstop             Boolean               @default(false) @map("prefers_nonstop")
  maxLayoverMinutes          Int?                  @map("max_layover_minutes")
  willingToReposition        Boolean               @default(false) @map("willing_to_reposition")
  redemptionStyle            RedemptionStyle       @default(balanced) @map("redemption_style")
  avoidBasicEconomy          Boolean               @default(false) @map("avoid_basic_economy")
  preferredAirlines          Json?                 @map("preferred_airlines")
  avoidedAirlines            Json?                 @map("avoided_airlines")
  notes                      String?
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")
  accessibilityNeeds         Json?                 @map("accessibility_needs")
  activityPreferences        Json?                 @map("activity_preferences")
  budgetSensitivity          BudgetSensitivity?    @map("budget_sensitivity")
  dealbreakers               Json?
  dislikes                   Json?
  familyConsiderations       String?               @map("family_considerations")
  foodPreferences            Json?                 @map("food_preferences")
  lastUpdatedSource          PreferenceSource      @default(manual) @map("last_updated_source")
  locationPreferences        String?               @map("location_preferences")
  mergeStrategy              MergeStrategy         @default(merge) @map("merge_strategy")
  pointsVsCash               String?               @map("points_vs_cash")
  preferredHotelTypes        Json?                 @map("preferred_hotel_types")
  roomPreferences            Json?                 @map("room_preferences")
  specialOccasions           Json?                 @map("special_occasions")
  loyaltyNotes               String?               @map("loyalty_notes")
  budgetNotes                String?               @map("budget_notes")
  preferredDestinations      Json?                 @map("preferred_destinations")
  preferredDepartureAirports Json?                 @map("preferred_departure_airports")
  dateFlexibility            String?               @map("date_flexibility")
  travelPace                 String?               @map("travel_pace")
  pastTripFeedback           String?               @map("past_trip_feedback")
  client                     Client                @relation(fields: [clientId], references: [id])
  changelog                  PreferenceChangeLog[]

  @@map("client_preferences")
}

model PreferenceChangeLog {
  id              String           @id @default(cuid())
  preferenceId    String           @map("preference_id")
  changedByUserId String           @map("changed_by_user_id")
  source          PreferenceSource
  fieldName       String           @map("field_name")
  oldValue        Json?            @map("old_value")
  newValue        Json?            @map("new_value")
  createdAt       DateTime         @default(now()) @map("created_at")
  changedBy       User             @relation(fields: [changedByUserId], references: [id])
  preference      ClientPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@index([preferenceId])
  @@map("preference_change_logs")
}

model TripRequest {
  id                  String               @id @default(cuid())
  organizationId      String               @map("organization_id")
  ownerUserId         String               @map("owner_user_id")
  clientId            String?              @map("client_id")
  householdId         String?              @map("household_id")
  title               String
  originAirports      Json                 @map("origin_airports")
  destinationAirports Json                 @map("destination_airports")
  departureDate       DateTime             @map("departure_date")
  returnDate          DateTime?            @map("return_date")
  travelerCount       Int                  @default(1) @map("traveler_count")
  cabinPreference     CabinPreference      @default(economy) @map("cabin_preference")
  flexibilityDays     Int?                 @map("flexibility_days")
  budgetCash          Int?                 @map("budget_cash")
  pointBalances       Json?                @map("point_balances")
  notes               String?
  status              TripStatus           @default(draft)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  alertSubscriptions  AlertSubscription[]
  settlements         GroupSettlement[]
  itineraryJobs       ItineraryJob[]
  recommendationRuns  RecommendationRun[]
  tripBriefs          TripBrief[]
  client              Client?              @relation(fields: [clientId], references: [id])
  household           Household?           @relation(fields: [householdId], references: [id])
  organization        Organization         @relation(fields: [organizationId], references: [id])
  owner               User                 @relation(fields: [ownerUserId], references: [id])
  tradeoffRanking     TripTradeoffRanking?
  travelers           TripTraveler[]

  @@index([organizationId])
  @@index([clientId])
  @@index([householdId])
  @@map("trip_requests")
}

model TripTradeoffRanking {
  id                String      @id @default(cuid())
  tripRequestId     String      @unique @map("trip_request_id")
  cashCost          Int         @default(50) @map("cash_cost")
  pointsUsage       Int         @default(50) @map("points_usage")
  redemptionValue   Int         @default(50) @map("redemption_value")
  travelTime        Int         @default(50) @map("travel_time")
  fewestLayovers    Int         @default(50) @map("fewest_layovers")
  premiumExperience Int         @default(50) @map("premium_experience")
  flexibility       Int         @default(50)
  familyConvenience Int         @default(50) @map("family_convenience")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  tripRequest       TripRequest @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)

  @@map("trip_tradeoff_rankings")
}

model TripTraveler {
  id                     String                             @id @default(cuid())
  tripRequestId          String                             @map("trip_request_id")
  clientId               String                             @map("client_id")
  travelerType           TravelerType                       @default(adult) @map("traveler_type")
  mustTravelWithClientId String?                            @map("must_travel_with_client_id")
  createdAt              DateTime                           @default(now()) @map("created_at")
  originAirports         Json?                              @map("origin_airports")
  destinationAirports    Json?                              @map("destination_airports")
  useLeaderCities        Boolean                            @default(false) @map("use_leader_cities")
  cabinPreference        CabinPreference?                   @map("cabin_preference")
  departureDate          DateTime?                          @map("departure_date")
  returnDate             DateTime?                          @map("return_date")
  allocations            RecommendationTravelerAllocation[]
  client                 Client                             @relation(fields: [clientId], references: [id])
  tripRequest            TripRequest                        @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)

  @@map("trip_travelers")
}

model RecommendationRun {
  id              String                 @id @default(cuid())
  tripRequestId   String                 @map("trip_request_id")
  createdByUserId String                 @map("created_by_user_id")
  status          RunStatus              @default(queued)
  modelVersion    String?                @map("model_version")
  engineVersion   String                 @default("v1") @map("engine_version")
  createdAt       DateTime               @default(now()) @map("created_at")
  completedAt     DateTime?              @map("completed_at")
  memo            RecommendationMemo?
  options         RecommendationOption[]
  createdBy       User                   @relation(fields: [createdByUserId], references: [id])
  tripRequest     TripRequest            @relation(fields: [tripRequestId], references: [id])

  @@index([tripRequestId])
  @@map("recommendation_runs")
}

model RecommendationOption {
  id                       String                             @id @default(cuid())
  recommendationRunId      String                             @map("recommendation_run_id")
  rank                     Int
  title                    String
  strategyType             StrategyType                       @map("strategy_type")
  totalCashCost            Int                                @map("total_cash_cost")
  totalPointsUsed          Json                               @map("total_points_used")
  estimatedTotalValueCents Int?                               @map("estimated_total_value_cents")
  weightedScore            Float?                             @map("weighted_score")
  isRecommended            Boolean                            @default(false) @map("is_recommended")
  summary                  String
  createdAt                DateTime                           @default(now()) @map("created_at")
  insights                 RecommendationInsight[]
  recommendationRun        RecommendationRun                  @relation(fields: [recommendationRunId], references: [id], onDelete: Cascade)
  travelerAllocations      RecommendationTravelerAllocation[]

  @@index([recommendationRunId])
  @@map("recommendation_options")
}

model RecommendationTravelerAllocation {
  id                     String               @id @default(cuid())
  recommendationOptionId String               @map("recommendation_option_id")
  tripTravelerId         String               @map("trip_traveler_id")
  paymentType            PaymentType          @map("payment_type")
  loyaltyProgramId       String?              @map("loyalty_program_id")
  pointsUsed             Int?                 @map("points_used")
  cashUsed               Int?                 @map("cash_used")
  taxesAndFees           Int?                 @map("taxes_and_fees")
  rationale              String?
  createdAt              DateTime             @default(now()) @map("created_at")
  pointSourceClientId    String?              @map("point_source_client_id")
  pointValueCents        Float?               @map("point_value_cents")
  loyaltyProgram         LoyaltyProgram?      @relation(fields: [loyaltyProgramId], references: [id])
  pointSourceClient      Client?              @relation("PointSource", fields: [pointSourceClientId], references: [id])
  recommendationOption   RecommendationOption @relation(fields: [recommendationOptionId], references: [id], onDelete: Cascade)
  tripTraveler           TripTraveler         @relation(fields: [tripTravelerId], references: [id])

  @@map("recommendation_traveler_allocations")
}

model RecommendationInsight {
  id                     String               @id @default(cuid())
  recommendationOptionId String               @map("recommendation_option_id")
  insightType            InsightType          @map("insight_type")
  title                  String
  body                   String
  severity               Severity             @default(info)
  createdAt              DateTime             @default(now()) @map("created_at")
  recommendationOption   RecommendationOption @relation(fields: [recommendationOptionId], references: [id], onDelete: Cascade)

  @@map("recommendation_insights")
}

model RecommendationMemo {
  id                  String            @id @default(cuid())
  recommendationRunId String            @unique @map("recommendation_run_id")
  internalSummary     String?           @map("internal_summary")
  clientSummary       String?           @map("client_summary")
  emailDraft          String?           @map("email_draft")
  pdfUrl              String?           @map("pdf_url")
  shareToken          String?           @unique @map("share_token")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  recommendationRun   RecommendationRun @relation(fields: [recommendationRunId], references: [id])

  @@map("recommendation_memos")
}

model GroupSettlement {
  id                   String                @id @default(cuid())
  tripRequestId        String                @map("trip_request_id")
  createdByClientId    String?               @map("created_by_client_id")
  splitMethod          SettlementSplitMethod @default(proportional_to_cost) @map("split_method")
  pointValuationMethod PointValuationMethod  @default(actual_redemption) @map("point_valuation_method")
  contributionLedger   Json                  @map("contribution_ledger")
  fairShares           Json                  @map("fair_shares")
  transfers            Json
  memo                 String?
  engineVersion        String                @default("v1") @map("engine_version")
  createdAt            DateTime              @default(now()) @map("created_at")
  createdBy            Client?               @relation(fields: [createdByClientId], references: [id])
  tripRequest          TripRequest           @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)

  @@index([tripRequestId])
  @@map("group_settlements")
}

model ClientIntake {
  id                           String               @id @default(cuid())
  clientId                     String               @map("client_id")
  createdByUserId              String               @map("created_by_user_id")
  status                       IntakeStatus         @default(draft)
  isTemplate                   Boolean              @default(false) @map("is_template")
  templateName                 String?              @map("template_name")
  duplicatedFromId             String?              @map("duplicated_from_id")
  tripType                     TripType?            @map("trip_type")
  tripTypeOther                String?              @map("trip_type_other")
  destinations                 Json?
  departureAirports            Json?                @map("departure_airports")
  dateFlexibility              DateFlexibility?     @map("date_flexibility")
  earliestDeparture            DateTime?            @map("earliest_departure")
  latestReturn                 DateTime?            @map("latest_return")
  tripDurationDays             Int?                 @map("trip_duration_days")
  budgetMin                    Int?                 @map("budget_min")
  budgetMax                    Int?                 @map("budget_max")
  budgetCurrency               String               @default("USD") @map("budget_currency")
  budgetNotes                  String?              @map("budget_notes")
  preferredFlightRouting       String?              @map("preferred_flight_routing")
  cabinPreference              CabinPreference?     @map("cabin_preference")
  hotelStyles                  Json?                @map("hotel_styles")
  loyaltyNotes                 String?              @map("loyalty_notes")
  accessibilityNeeds           String?              @map("accessibility_needs")
  dietaryNeeds                 String?              @map("dietary_needs")
  travelPace                   TravelPace?          @map("travel_pace")
  layoverTolerance             LayoverTolerance?    @map("layover_tolerance")
  luxuryPreference             LuxuryPreference?    @map("luxury_preference")
  familyFriendly               Boolean?             @map("family_friendly")
  travelerCount                Int?                 @map("traveler_count")
  childrenCount                Int?                 @map("children_count")
  childrenAges                 Json?                @map("children_ages")
  desiredExperiences           Json?                @map("desired_experiences")
  dealbreakers                 Json?
  preferredAirlines            Json?                @map("preferred_airlines")
  avoidedAirlines              Json?                @map("avoided_airlines")
  preferredAccommodationBrands Json?                @map("preferred_accommodation_brands")
  accommodationDealbreakers    Json?                @map("accommodation_dealbreakers")
  notes                        String?
  completedAt                  DateTime?            @map("completed_at")
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")
  client                       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  duplicatedFrom               ClientIntake?        @relation("IntakeDuplicate", fields: [duplicatedFromId], references: [id])
  duplicates                   ClientIntake[]       @relation("IntakeDuplicate")
  followUpSuggestions          FollowUpSuggestion[]
  formTokens                   IntakeFormToken[]
  tripBriefs                   TripBrief[]

  @@index([clientId])
  @@index([createdByUserId])
  @@map("client_intakes")
}

model TripBrief {
  id                  String        @id @default(cuid())
  tripRequestId       String?       @map("trip_request_id")
  clientId            String        @map("client_id")
  intakeId            String?       @map("intake_id")
  generatedByUserId   String        @map("generated_by_user_id")
  version             Int           @default(1)
  executiveSummary    String?       @map("executive_summary")
  hardConstraints     String?       @map("hard_constraints")
  softPreferences     String?       @map("soft_preferences")
  pointsCashPosture   String?       @map("points_cash_posture")
  acceptableTradeoffs String?       @map("acceptable_tradeoffs")
  doNotRecommend      String?       @map("do_not_recommend")
  operationalNotes    String?       @map("operational_notes")
  isEdited            Boolean       @default(false) @map("is_edited")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  client              Client        @relation(fields: [clientId], references: [id])
  generatedBy         User          @relation(fields: [generatedByUserId], references: [id])
  intake              ClientIntake? @relation(fields: [intakeId], references: [id])
  tripRequest         TripRequest?  @relation(fields: [tripRequestId], references: [id])

  @@index([tripRequestId])
  @@index([clientId])
  @@map("trip_briefs")
}

model AlertSubscription {
  id              String          @id @default(cuid())
  organizationId  String          @map("organization_id")
  clientId        String?         @map("client_id")
  householdId     String?         @map("household_id")
  tripRequestId   String?         @map("trip_request_id")
  alertType       AlertType       @map("alert_type")
  targetProgramId String?         @map("target_program_id")
  targetRoute     Json?           @map("target_route")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  events          AlertEvent[]
  client          Client?         @relation(fields: [clientId], references: [id])
  household       Household?      @relation(fields: [householdId], references: [id])
  organization    Organization    @relation(fields: [organizationId], references: [id])
  targetProgram   LoyaltyProgram? @relation(fields: [targetProgramId], references: [id])
  tripRequest     TripRequest?    @relation(fields: [tripRequestId], references: [id])

  @@index([organizationId])
  @@map("alert_subscriptions")
}

model AlertEvent {
  id                  String            @id @default(cuid())
  alertSubscriptionId String            @map("alert_subscription_id")
  title               String
  body                String
  metadata            Json?
  triggeredAt         DateTime          @default(now()) @map("triggered_at")
  isRead              Boolean           @default(false) @map("is_read")
  alertSubscription   AlertSubscription @relation(fields: [alertSubscriptionId], references: [id], onDelete: Cascade)

  @@map("alert_events")
}

model InferredPreference {
  id               String            @id @default(cuid())
  clientId         String            @map("client_id")
  category         InferenceCategory
  label            String
  description      String
  confidence       Float
  evidence         Json
  status           InferenceStatus   @default(pending)
  resolvedAt       DateTime?         @map("resolved_at")
  resolvedByUserId String?           @map("resolved_by_user_id")
  appliedToProfile Boolean           @default(false) @map("applied_to_profile")
  source           String            @default("trip_history")
  sourceField      String?           @map("source_field")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resolvedBy       User?             @relation(fields: [resolvedByUserId], references: [id])

  @@index([clientId])
  @@map("inferred_preferences")
}

model FollowUpSuggestion {
  id              String             @id @default(cuid())
  clientId        String             @map("client_id")
  intakeId        String?            @map("intake_id")
  category        SuggestionCategory
  priority        SuggestionPriority
  questionText    String             @map("question_text")
  reason          String
  ruleKey         String             @map("rule_key")
  status          SuggestionStatus   @default(pending)
  statusChangedAt DateTime?          @map("status_changed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  intake          ClientIntake?      @relation(fields: [intakeId], references: [id])

  @@index([clientId])
  @@index([clientId, status])
  @@map("follow_up_suggestions")
}

model ItineraryJob {
  id            String             @id @default(cuid())
  tripRequestId String             @map("trip_request_id")
  status        ItineraryJobStatus @default(processing)
  result        Json?
  error         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  completedAt   DateTime?          @map("completed_at")
  tripRequest   TripRequest        @relation(fields: [tripRequestId], references: [id], onDelete: Cascade)

  @@index([tripRequestId])
  @@map("itinerary_jobs")
}

model GroupProfile {
  id              String             @id @default(cuid())
  clientId        String             @unique @map("client_id")
  groupType       GroupType          @default(leisure_friends) @map("group_type")
  estimatedSize   Int?               @map("estimated_size")
  ageSpread       String?            @map("age_spread")
  decisionStyle   GroupDecisionStyle @default(consensus) @map("decision_style")
  roomArrangement String?            @map("room_arrangement")
  sharedBilling   Boolean            @default(false) @map("shared_billing")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  members         GroupMember[]
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("group_profiles")
}

model GroupMember {
  id             String       @id @default(cuid())
  groupProfileId String       @map("group_profile_id")
  linkedClientId String?      @map("linked_client_id")
  name           String
  email          String?
  departureCity  String?      @map("departure_city")
  isOrganizer    Boolean      @default(false) @map("is_organizer")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  groupProfile   GroupProfile @relation(fields: [groupProfileId], references: [id], onDelete: Cascade)
  linkedClient   Client?      @relation("GroupMemberLinkedClient", fields: [linkedClientId], references: [id])

  @@index([groupProfileId])
  @@map("group_members")
}

model BusinessProfile {
  id                  String             @id @default(cuid())
  clientId            String             @unique @map("client_id")
  companyName         String             @map("company_name")
  industry            String?
  companySize         String?            @map("company_size")
  billingContactName  String?            @map("billing_contact_name")
  billingContactEmail String?            @map("billing_contact_email")
  requiresPreApproval Boolean            @default(false) @map("requires_pre_approval")
  maxNightlyRateUsd   Int?               @map("max_nightly_rate_usd")
  travelPolicyNotes   String?            @map("travel_policy_notes")
  corporateAccountIds Json?              @map("corporate_account_ids")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  client              Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  travelers           BusinessTraveler[]

  @@map("business_profiles")
}

model BusinessTraveler {
  id                String          @id @default(cuid())
  businessProfileId String          @map("business_profile_id")
  linkedClientId    String?         @map("linked_client_id")
  name              String
  email             String?
  role              String?
  seniorityTier     String?         @map("seniority_tier")
  notes             String?
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  linkedClient      Client?         @relation("BusinessTravelerLinkedClient", fields: [linkedClientId], references: [id])

  @@index([businessProfileId])
  @@map("business_travelers")
}

model IntakeFormToken {
  id              String            @id @default(cuid())
  token           String            @unique
  clientId        String            @map("client_id")
  intakeId        String?           @map("intake_id")
  recipientEmail  String            @map("recipient_email")
  recipientName   String?           @map("recipient_name")
  formVariant     IntakeFormVariant @map("form_variant")
  groupSize       Int?              @map("group_size")
  customQuestions Json?             @map("custom_questions")
  formAnswers     Json?             @map("form_answers")
  advisorEmail    String?           @map("advisor_email")
  sentAt          DateTime?         @map("sent_at")
  openedAt        DateTime?         @map("opened_at")
  completedAt     DateTime?         @map("completed_at")
  expiresAt       DateTime          @map("expires_at")
  reminderSentAt  DateTime?         @map("reminder_sent_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  intake          ClientIntake?     @relation(fields: [intakeId], references: [id])

  @@index([clientId])
  @@index([token])
  @@map("intake_form_tokens")
}

