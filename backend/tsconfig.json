{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts"],
  "exclude": [
    "**/node_modules/**",
    "../**/node_modules/**",
    "../frontend/**",
    "**/.venv/**", "*/venv/**", "**/__pycache__/**",
    ".git", "cdk.out"
  ]
}
